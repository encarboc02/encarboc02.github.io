<!-- ABOUT -->
<section id="about">
    <div class="container">
        <div class="section-label">/ sobre mí</div>
        <div class="about-grid">
            <!-- Texto principal -->
            <div class="about-text">
                <h2 class="section-title">Donde la biología<br><em>se vuelve dato.</em></h2>
                <p>
                    Soy biotecnólogo y bioinformático enfocado en transformar datos biomédicos en insights estratégicos que impulsen la toma de decisiones y generen valor de negocio en healthcare.
                </p>
                <p>
                    Actualmente curso un Máster en Medicina Personalizada y Farmacogenómica y un MBA en Industria Farmacéutica. Tengo experiencia en análisis de datos, integración de información e IA aplicada con R, Python y SQL. Mi perfil es analítico, orientado a resultados y capaz de traducir necesidades de negocio en soluciones basadas en datos.
                </p>
                <p>
                    Interesado en áreas como Consultoría, BI, Data Analyst, Data Entry, Bioinformática y AI en Industria sanitaria/biotech.
                </p>
            </div>

            <!-- Tabs de Skills y Educación -->
            <div class="about-tabs">
                <div class="tab-nav">
                    <button class="tab-btn active" data-tab="skills">Skills</button>
                    <button class="tab-btn" data-tab="education">Educación</button>
                </div>

                <!-- Skills -->
                <div class="tab-panel active" id="skills">
                    <!-- Technical Skills -->
                    <div class="skill-item">
                        <div class="skill-tag">Technical Skills</div>
                        <p>Python, R, SQL, Power BI, Machine Learning, RNA-Seq, Integración multi-ómica, Dashboards analíticos, IA aplicada a salud</p>
                    </div>
                    <!-- Soft Skills -->
                    <div class="skill-item">
                        <div class="skill-tag">Soft Skills</div>
                        <p>Perfil analítico, Orientación a resultados, Comunicación efectiva, Resolución de problemas, Traducción de necesidades de negocio a soluciones basadas en datos</p>
                    </div>
                </div>

                <!-- Educación -->
                <div class="tab-panel" id="education">
                    <div class="skill-item">
                        <div class="skill-tag">MBA en Industria Farmacéutica</div>
                        <p>Bioempower Leaders — 02/26 - Actualidad</p>
                    </div>
                    <div class="skill-item">
                        <div class="skill-tag">Máster en Medicina Personalizada y Farmacogenómica</div>
                        <p>Duponte — 12/25 - Actualidad</p>
                    </div>
                    <div class="skill-item">
                        <div class="skill-tag">Máster en Bioinformática</div>
                        <p>Universidad Internacional de La Rioja — 09/24 - 10/25</p>
                    </div>
                    <div class="skill-item">
                        <div class="skill-tag">Grado en Biotecnología</div>
                        <p>Universidad Pablo de Olavide — 09/2020 - 06/2024</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SERVICES -->
<section id="services">
    <div class="container">
        <div class="section-label">/ qué hago</div>
        <h2 class="section-title">Áreas de<br><em>especialización.</em></h2>
        <div class="services-grid">
            <div class="service-card" data-num="01">
                <div class="service-icon">🧬</div>
                <h3>Bioinformática</h3>
                <p>Análisis de datos genómicos y transcriptómicos para entender enfermedades y tratamientos. Pipelines reproducibles, integración multi-ómica.</p>
                <div class="service-tags">
                    <span>RNA-Seq</span><span>Python</span><span>R</span>
                </div>
            </div>
            <div class="service-card" data-num="02">
                <div class="service-icon">📊</div>
                <h3>Data Analytics & BI</h3>
                <p>Transformo datos en dashboards y decisiones estratégicas en salud y pharma. Del dato crudo a la historia que importa.</p>
                <div class="service-tags">
                    <span>Power BI</span><span>SQL</span><span>Python</span>
                </div>
            </div>
            <div class="service-card" data-num="03">
                <div class="service-icon">🤖</div>
                <h3>IA aplicada a salud</h3>
                <p>Modelos predictivos y machine learning para descubrimiento de fármacos, farmacovigilancia y soporte a decisiones clínicas.</p>
                <div class="service-tags">
                    <span>ML</span><span>Azure AI</span><span>Scikit-learn</span>
                </div>
            </div>
        </div>
    </div>
</section>

