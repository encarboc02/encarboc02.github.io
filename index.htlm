                    <a href="https://github.com/encarboc02/Clinical_Trials_BI">GitHub</a>
                </div>
            </div>

            <div class="work">
                <div class="layer">
                    <h3>FAERS Analysis</h3>
                    <p>Detección de señales de seguridad en medicamentos usando ML.</p>
                    <a href="https://github.com/encarboc02/Self_learning_projects">GitHub</a>
                </div>
            </div>
        </div>
