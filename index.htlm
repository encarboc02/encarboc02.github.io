<!-- HERO -->
<section id="hero">
    <div class="hero-bg">
        <div class="grid-overlay"></div>
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <div class="hero-content">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            <span>Apasionado por los datos, biología y negocio</span>
        </div>

        <h1 class="hero-title">
            <span class="line">Bioinformática</span>
            <span class="line italic">& Data Analytics</span>
            <span class="line">para la industria sanitaria</span>
        </h1>

        <p class="hero-sub">
            Soy <strong>Enrique Carnerero</strong> — biotecnólogo y bioinformático. Actualmente disfruto aprendiendo continuamente mientras desarrollo proyectos en bioinformática, análisis de datos y business intelligence, además de trabajar en aplicaciones de IA en salud.
        </p>

        <div class="hero-actions">
